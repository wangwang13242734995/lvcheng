generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String    @id @default(cuid())
  name                String
  email               String    @unique
  password            String
  role                String    @default("STUDENT")
  avatar              String?
  school              String?
  major               String?
  graduationYear      Int?
  bio                 String?
  skills              String?
  resetToken          String?
  resetTokenExpiry    DateTime?
  createdAt           DateTime  @default(now())

  projects            Project[]
  abilityScores       AbilityScore[]
  growthRecords       GrowthRecord[]
  weeklyReports       WeeklyReport[]
  timeCapsules        TimeCapsule[]
  challengeApplications ChallengeApplication[]
  challengeSubmissions ChallengeSubmission[]
  badges              Badge[]
  certificates        Certificate[]
}

model Project {
  id                  String   @id @default(cuid())
  userId              String
  title               String
  type                String
  role                String?
  teamSize            Int?
  startDate           DateTime?
  endDate             DateTime?
  techStack           String?
  description         String?
  difficulty          String?
  outcome             String?
  outcomeType         String?
  outcomeData         String?
  difficultyEncountered String?
  solution            String?
  links               String?
  attachments         String?
  videoUrl            String?
  status              String   @default("DRAFT")
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user              User     @relation(fields: [userId], references: [id])
  growthRecords     GrowthRecord[]
}

model AbilityScore {
  id            String   @id @default(cuid())
  userId        String
  craft         Int      @default(30)
  learn         Int      @default(30)
  drive         Int      @default(30)
  team          Int      @default(30)
  grit          Int      @default(30)
  express       Int      @default(30)
  totalScore    Int      @default(30)
  calculatedAt  DateTime @default(now())

  user          User     @relation(fields: [userId], references: [id])
}

model GrowthRecord {
  id              String   @id @default(cuid())
  userId          String
  projectId       String?
  type            String
  title           String
  content         String?
  abilitySignals  String?
  date            DateTime @default(now())
  createdAt       DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
  project         Project? @relation(fields: [projectId], references: [id])
}

model WeeklyReport {
  id              String   @id @default(cuid())
  userId          String
  weekStart       DateTime
  weekEnd         DateTime
  recordCount     Int      @default(0)
  abilityChanges  String?
  hoursInvested   Float    @default(0)
  aiSuggestion    String?
  generatedAt     DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model TimeCapsule {
  id        String    @id @default(cuid())
  userId    String
  goal      String
  writtenAt DateTime  @default(now())
  openDates String?
  openedAt  DateTime?

  user      User      @relation(fields: [userId], references: [id])
}

model Challenge {
  id              String   @id @default(cuid())
  company         String
  title           String
  description     String
  category        String   @default("TECH")
  requiredCraft   Int      @default(0)
  requiredLearn   Int      @default(0)
  requiredDrive   Int      @default(0)
  requiredTeam    Int      @default(0)
  requiredGrit    Int      @default(0)
  requiredExpress Int      @default(0)
  reward          String?
  rewardAmount    Int      @default(0)
  rewardType      String   @default("CERTIFICATE")
  deadline        DateTime?
  spots           Int?
  status          String   @default("OPEN")
  createdAt       DateTime @default(now())

  applications    ChallengeApplication[]
  submissions     ChallengeSubmission[]
}

model ChallengeApplication {
  id          String   @id @default(cuid())
  challengeId String
  userId      String
  status      String   @default("PENDING")
  appliedAt   DateTime @default(now())

  challenge   Challenge @relation(fields: [challengeId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
  submission  ChallengeSubmission?
}

model ChallengeSubmission {
  id              String   @id @default(cuid())
  challengeId     String
  userId          String
  applicationId   String?   @unique
  title           String
  description     String
  solutionUrl     String?
  attachments     String?
  status          String   @default("PENDING")
  reviewComment   String?
  reviewedBy      String?
  reviewedAt      DateTime?
  abilityGrowth   String?
  createdAt       DateTime @default(now())

  challenge       Challenge @relation(fields: [challengeId], references: [id])
  user            User      @relation(fields: [userId], references: [id])
  application     ChallengeApplication? @relation(fields: [applicationId], references: [id])
}

model Badge {
  id              String   @id @default(cuid())
  userId          String
  name            String
  description     String
  level           String   @default("BRONZE")
  icon            String   @default("🏅")
  challengeId     String?
  company         String?
  earnedAt        DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}

model Certificate {
  id              String   @id @default(cuid())
  userId          String
  title           String
  description     String
  issuer          String
  issuerLogo      String?
  craftScore      Int      @default(0)
  learnScore      Int      @default(0)
  driveScore      Int      @default(0)
  teamScore       Int      @default(0)
  gritScore       Int      @default(0)
  expressScore    Int      @default(0)
  challengeId     String?
  issuedAt        DateTime @default(now())

  user            User     @relation(fields: [userId], references: [id])
}
